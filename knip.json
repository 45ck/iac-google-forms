{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "workspaces": {
    ".": {
      "entry": ["scripts/*.js"],
      "project": ["scripts/**/*.js"]
    },
    "packages/planning-hub": {
      "entry": ["src/docs/**/*.mdx", ".storybook/*.ts", "scripts/*.js"],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.js"]
    },
    "packages/ui": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  },
  "ignore": ["dist/**", "coverage/**", "node_modules/**"],
  "treatConfigHintsAsErrors": true
}
